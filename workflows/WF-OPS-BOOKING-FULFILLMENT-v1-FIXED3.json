    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key={{ $vars.GEMINI_API_KEY }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={\n  \"contents\": [{\"parts\": [{\"text\": \"Analiza el siguiente correo de confirmación de un mayorista hotelero y extrae el código de confirmación o localizador de reserva.\\n\\nCORREO DEL PROVEEDOR:\\n{{ $json.text || $json.snippet || '' }}\\n\\nResponde SOLO con JSON válido, sin markdown:\\n{\\n  \\\"locator_found\\\": true/false,\\n  \\\"provider_locator\\\": \\\"CODIGO123\\\" o null,\\n  \\\"confidence\\\": \\\"alta/media/baja\\\",\\n  \\\"raw_snippet\\\": \\\"fragmento del texto donde encontraste el código\\\"\\n}\\n\\nBusca patrones como: \\\"Número de reserva:\\\", \\\"Localizador:\\\", \\\"Ref:\\\", \\\"Confirmation:\\\", \\\"Booking code:\\\", \\\"Código:\\\", combinaciones de letras y números de 4-12 caracteres típicos de sistemas hoteleros.\"}]}],\n  \"generationConfig\": {\"response_mime_type\": \"application/json\", \"temperature\": 0.1, \"maxOutputTokens\": 256}\n}",
        "options": {
          "timeout": 20000
        }
      },
      "id": "64bfafe1-0bc4-45df-9a38-6ef90cbe2098",
      "name": "12_GEMINI_EXTRAER_LOCALIZADOR",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        10896,
        6208
      ]
    },
    {
      "parameters": {
        "jsCode": "const geminiRaw = $input.first().json;\nconst booking   = $('10C_SPLIT_WAITING').item.json;\nconst lead      = booking.leads || {};\nconst offer     = booking.marketing_offers || {};\n\nlet extracted = {};\ntry {\n  const txt = geminiRaw.candidates?.[0]?.content?.parts?.[0]?.text || '{}';\n  extracted = JSON.parse(txt.replace(/```json|```/g, '').trim());\n} catch(e) {\n  extracted = { locator_found: false, provider_locator: null };\n}\n\nif (!extracted.locator_found || !extracted.provider_locator) {\n  return [{ json: { _skip: true, booking_id: booking.id, _reason: 'Sin localizador detectado' } }];\n}\n\nreturn [{json: {\n  booking_id:       booking.id,\n  provider_locator: extracted.provider_locator,\n  confidence:       extracted.confidence,\n  // Cliente para WhatsApp\n  client_name:      `${lead.first_name || ''} ${lead.last_name || ''}`.trim(),\n  client_phone:     lead.phone || '',\n  client_email:     lead.email || '',\n  hotel_name:       offer.title || 'el hotel',\n  hotel_slug:       offer.hotel_slug || '',\n  check_in:         booking.check_in,\n  check_out:        booking.check_out,\n  provider_name:    booking.provider_name,\n  _skip: false\n}}];"
      },
