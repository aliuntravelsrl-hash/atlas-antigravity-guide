    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key={{ $vars.GEMINI_API_KEY }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={\n  \"contents\": [{\"parts\": [{\"text\": \"Eres el asistente de reservas de Aliun Travel SRL, agencia de viajes dominicana. Redacta un correo FORMAL en español para solicitar el bloqueo de habitaciones a un mayorista hotelero.\\n\\nDATOS DE LA RESERVA:\\n- Hotel: {{ $json.hotel_name }}\\n- Tipo de Oferta: {{ $json.offer_type }}\\n- Check-in: {{ $json.check_in }}\\n- Check-out: {{ $json.check_out }}\\n- Referencia interna: {{ $json.booking_ref }}\\n- Huéspedes adultos: {{ $json.adult_names }}\\n- {{ $json.children_info }}\\n- Condición de ocupación: {{ $json.occupancy_desc || 'Estándar' }}\\n- Monto total: USD ${{ $json.total_amount }}\\n\\nINSTRUCCIONES:\\n1. Saludo formal de negocios\\n2. Solicitar confirmación de disponibilidad y bloqueo de habitación\\n3. Listar datos de viajeros con claridad\\n4. Indicar fechas exactas de entrada y salida\\n5. Mencionar la condición de ocupación si aplica (niños gratis, etc.)\\n6. Solicitar código de confirmación/localizador para nuestros registros\\n7. Cierre profesional con nombre Aliun Travel SRL\\n8. Tono: profesional, conciso, cordial\\n\\nResponde SOLO con el texto del email (sin asunto, sin markdown, sin explicaciones).\"}]}],\n  \"generationConfig\": {\"temperature\": 0.3, \"maxOutputTokens\": 1024}\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "a98ee549-9900-4126-8831-2f780f60d245",
      "name": "04_GEMINI_COPYWRITER_B2B",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        10896,
        5440
      ]
    },
    {
      "parameters": {
        "jsCode": "const geminiRaw = $input.first().json;\nconst booking   = $('03_MAPEAR_EMAIL_PROVEEDOR').item.json;\n\nconst emailBody = geminiRaw.candidates?.[0]?.content?.parts?.[0]?.text || \n  `Estimados,\\n\\nSolicitamos confirmación de reserva para ${booking.client_name} en ${booking.hotel_name}.\\nCheck-in: ${booking.check_in} | Check-out: ${booking.check_out}\\nRef: ${booking.booking_ref}\\n\\nQuedamos atentos.\\nAliun Travel SRL`;\n\nconst subject = `Solicitud de Bloqueo — ${booking.hotel_name} | Ref: ${booking.booking_ref} | ${booking.check_in}`;\n\nreturn [{json: {\n  ...booking,\n  email_subject: subject,\n  email_body: emailBody,\n  to_email: booking.provider_email\n}}];"
      },
