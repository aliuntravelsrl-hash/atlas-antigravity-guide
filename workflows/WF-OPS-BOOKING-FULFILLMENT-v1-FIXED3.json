    {
      "parameters": {
        "jsCode": "// Supabase HTTP devuelve el array directamente como $json\n// Este nodo convierte [{booking1},{booking2}] en items individuales\nconst data = $input.first().json;\nconst arr = Array.isArray(data) ? data : [];\nif (arr.length === 0) return [];\nreturn arr.map(item => ({ json: item }));"
      },
      "id": "c52285e8-f495-45dd-a607-0ff6437fd02f",
      "name": "02C_SPLIT_BOOKINGS",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        10176,
        5440
      ]
    },
    {
      "parameters": {
        "jsCode": "// ═══ MATRIZ TEMPORAL DE PROVEEDORES ═══\n// Actualizar cuando se confirme el dominio de Deseo\nconst PROVIDER_EMAIL_MAP = {\n  'soltravel':   'soltravel06@gmail.com',\n  'deseo':       'deseoreservas@gniall.com.do',   // ⚠️ Verificar dominio con Director\n  'opera':       'ventas8@operahotel.com.do',\n  'sunparadise': 'sunreservas@sunparadise.com.do',\n  'tierraverde': 'reservas@mitierraverde.com',\n};\n\nconst booking = $input.first().json;\nconst lead    = booking.leads || {};\nconst offer   = booking.marketing_offers || {};\n\n// Normalizar provider_name: viene de bookings.provider_name o de la oferta\nconst rawProvider = (booking.provider_name || offer.source_channel || '').toLowerCase().trim();\n\n// Match flexible: busca si alguna clave de la matriz aparece en el provider_name\nlet matchedKey = null;\nfor (const key of Object.keys(PROVIDER_EMAIL_MAP)) {\n  if (rawProvider.includes(key)) { matchedKey = key; break; }\n}\n\nconst providerEmail = matchedKey ? PROVIDER_EMAIL_MAP[matchedKey] : null;\n\nif (!providerEmail) {\n  // Sin match → marcar como fallido para revisión manual\n  return [{json: {\n    _skip: true,\n    _reason: `Sin email mapeado para proveedor: \"${rawProvider}\"`,\n    booking_id: booking.id,\n    provider_raw: rawProvider\n  }}];\n}\n\n// Construir listado de viajeros para el email\nlet paxDetails = [];\ntry { paxDetails = typeof booking.pax_details === 'string' ? JSON.parse(booking.pax_details) : (booking.pax_details || []); } catch(e) {}\nlet childrenAges = [];\ntry { childrenAges = typeof booking.children_ages === 'string' ? JSON.parse(booking.children_ages) : (booking.children_ages || []); } catch(e) {}\n\nconst adultNames = paxDetails.filter(p => p.type === 'adult').map(p => p.name).join(', ')\n  || `${lead.first_name || ''} ${lead.last_name || ''}`.trim()\n  || 'Viajero principal';\n\nconst childInfo = childrenAges.length > 0\n  ? `Niños: ${childrenAges.map((age, i) => `Niño ${i+1} (${age} años)`).join(', ')}`\n  : '';\n\nconst occupancy = booking.occupancy_desc || offer.occupancy_desc || '';\n\nreturn [{json: {\n  booking_id:     booking.id,\n  lead_id:        booking.lead_id,\n  hotel_name:     offer.title || 'Hotel',\n  hotel_slug:     offer.hotel_slug || '',\n  offer_type:     offer.offer_type || 'last_minute',\n  check_in:       booking.check_in,\n  check_out:      booking.check_out,\n  total_amount:   booking.total_amount,\n  booking_ref:    booking.booking_reference || booking.id.substring(0,8).toUpperCase(),\n  // Cliente\n  client_name:    `${lead.first_name || ''} ${lead.last_name || ''}`.trim(),\n  client_email:   lead.email || '',\n  client_phone:   lead.phone || '',\n  // Viajeros\n  adult_names:    adultNames,\n  children_info:  childInfo,\n  occupancy_desc: occupancy,\n  pax_count:      paxDetails.length || 1,\n  // Proveedor\n  provider_key:   matchedKey,\n  provider_email: providerEmail,\n  // Para el copywriter\n  _skip: false\n}}];\n"
      },
